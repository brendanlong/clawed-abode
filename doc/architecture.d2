# Clawed Abode - Architecture Diagram

direction: right

# External clients
mobile: Mobile/Web Browser

# Tailscale
tailscale: Tailscale Serve/Funnel {
  style.fill: "#4A5568"
}

# Home Server
server: Home Server {
  style.fill: "#E8F4FD"

  app: Next.js + tRPC {
    style.fill: "#0070F3"
    style.font-color: white

    auth: Auth
    session_mgmt: Session Management
    sdk: Claude Agent SDK (in-process)
    sse: SSE to Browser (multiplexed per-session + global list streams)
  }

  workspaces: ~/worktrees/ {
    style.fill: "#48BB78"
    style.font-color: white

    session1: "{sessionId1}/{repo}" {
      style.fill: "#38A169"
    }
    session2: "{sessionId2}/{repo}" {
      style.fill: "#38A169"
    }
  }

  db: SQLite {
    style.fill: "#F6E05E"

    sessions: Sessions
    messages: Messages
    settings: Settings
  }
}

# Connections
mobile -> tailscale: HTTPS
tailscale -> server.app: HTTP

server.app.sdk -> server.workspaces: "cwd"
server.app.session_mgmt -> server.db: "read/write"
server.app.sdk -> server.db.messages: "persist"
server.app.sse -> mobile: "stream events (resume via lastEventId)"

# Data Model
data: Data Model {
  style.fill: "#FFF5F5"

  session: Session {
    shape: class
    id: string
    name: string
    repoUrl: string?
    branch: string?
    status: creating | running | stopped | error | archived
    repoPath: string
  }

  message: Message {
    shape: class
    sessionId: string
    sequence: int
    type: system | user | assistant | result
    content: JSON
  }

  session -> message: "has many"
}

# Session Lifecycle
lifecycle: Session Lifecycle {
  style.fill: "#F0FFF4"

  create: Create {
    style.fill: "#C6F6D5"
    1: "User selects repo + branch"
    2: "Server clones to ~/worktrees/{id}/{repo}"
    3: "Session status → running"
  }

  interact: Interact {
    style.fill: "#BEE3F8"
    1: "User sends prompt via tRPC"
    2: "Push to the session's persistent streaming query() (revive w/ resume if needed)"
    3: "canUseTool handles AskUserQuestion"
    4: "Messages stream via SSE; query stays alive across turns"
    5: "Background tasks survive turn end (indicator only; never gate input)"
  }

  stop: Stop {
    style.fill: "#FEFCBF"
    1: "Interrupt = current turn only (query stays alive)"
    2: "Stop = close query; session status → stopped"
    3: "Worktree preserved on disk"
  }

  archive: Archive {
    style.fill: "#FED7D7"
    1: "Stop query if running"
    2: "Remove ~/worktrees/{id}/"
    3: "Session status → archived"
    4: "Messages preserved in DB"
  }

  create -> interact: "ready"
  interact -> stop: "user stops"
  stop -> interact: "user restarts"
  interact -> archive: "user deletes"
  stop -> archive: "user deletes"
}
