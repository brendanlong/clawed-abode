# Database
DATABASE_URL="file:./data/dev.db"

# GitHub Personal Access Token (with repo scope)
# Create at: https://github.com/settings/tokens
GITHUB_TOKEN="ghp_your_github_token_here"

# Claude Code OAuth token
# Run `claude setup-token` to generate - lasts for 1 year
CLAUDE_CODE_OAUTH_TOKEN="your_oauth_token_here"

# Claude model to use (e.g., "opus", "sonnet", "claude-opus-4-5-20251101")
CLAUDE_MODEL="opus[1m]"

# Branch prefix for session branches (e.g., "claude/" creates branches like "claude/{sessionId}")
SESSION_BRANCH_PREFIX="claude/"

# Node environment
NODE_ENV="development"

# For remote access, we recommend using Tailscale Funnel
# See: https://tailscale.com/kb/1223/funnel

# Password hash for authentication (base64-encoded)
# Generate with: pnpm hash-password <yourpassword>
# The output is base64-encoded to avoid issues with $ characters in dotenv
PASSWORD_HASH="JGFyZ29uMmlkJHY9MTkkbT02NTUzNix0PTMscD00JHlvdXJfc2FsdF9oZXJlJHlvdXJfaGFzaF9oZXJl"

# 32+ character key for encrypting secrets (env vars, MCP API keys)
# Generate with: openssl rand -base64 32
# ENCRYPTION_KEY=
